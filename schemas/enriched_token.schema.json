{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OnchainEnrichmentOutput",
  "type": "object",
  "required": [
    "contract_version",
    "generated_at",
    "tokens"
  ],
  "properties": {
    "contract_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "tokens": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "token_address",
          "top1_holder_share",
          "top20_holder_share",
          "first50_holder_conc_est",
          "holder_entropy_est",
          "unique_buyers_5m",
          "holder_growth_5m",
          "dev_sell_pressure_5m",
          "pumpfun_to_raydium_sec",
          "smart_wallet_hits",
          "smart_wallet_hit_wallets",
          "wallet_registry_status",
          "wallet_registry_hot_set_size",
          "wallet_registry_validated_size",
          "smart_wallet_score_sum",
          "smart_wallet_tier1_hits",
          "smart_wallet_tier2_hits",
          "smart_wallet_tier3_hits",
          "smart_wallet_early_entry_hits",
          "smart_wallet_active_hits",
          "smart_wallet_watch_hits",
          "smart_wallet_hit_tiers",
          "smart_wallet_hit_statuses",
          "smart_wallet_netflow_bias",
          "smart_wallet_conviction_bonus",
          "smart_wallet_registry_confidence",
          "enrichment_status",
          "enrichment_warnings",
          "enriched_at",
          "contract_version"
        ],
        "properties": {
          "token_address": {
            "type": "string",
            "minLength": 1
          },
          "bundle_count_first_60s": {
            "type": [
              "integer",
              "null"
            ]
          },
          "bundle_size_value": {
            "type": [
              "number",
              "null"
            ]
          },
          "unique_wallets_per_bundle_avg": {
            "type": [
              "number",
              "null"
            ]
          },
          "bundle_timing_from_liquidity_add_min": {
            "type": [
              "number",
              "null"
            ]
          },
          "bundle_success_rate": {
            "type": [
              "number",
              "null"
            ]
          },
          "bundle_composition_dominant": {
            "type": [
              "string",
              "null"
            ]
          },
          "bundle_tip_efficiency": {
            "type": [
              "number",
              "null"
            ]
          },
          "bundle_failure_retry_pattern": {
            "type": [
              "integer",
              "null"
            ]
          },
          "cross_block_bundle_correlation": {
            "type": [
              "number",
              "null"
            ]
          },
          "bundle_wallet_clustering_score": {
            "type": [
              "number",
              "null"
            ]
          },
          "cluster_concentration_ratio": {
            "type": [
              "number",
              "null"
            ]
          },
          "num_unique_clusters_first_60s": {
            "type": [
              "integer",
              "null"
            ]
          },
          "creator_in_cluster_flag": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "symbol": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "asset_metadata_present": {
            "type": "boolean"
          },
          "decimals": {
            "type": "integer"
          },
          "token_supply_raw": {
            "type": "string"
          },
          "token_supply_ui": {
            "type": "number"
          },
          "top1_holder_share": {
            "type": "number"
          },
          "top20_holder_share": {
            "type": "number"
          },
          "first50_holder_conc_est": {
            "type": "number"
          },
          "holder_entropy_est": {
            "type": "number"
          },
          "unique_buyers_5m": {
            "type": "integer"
          },
          "holder_growth_5m": {
            "type": "integer"
          },
          "dev_wallet_est": {
            "type": "string"
          },
          "dev_wallet_confidence_score": {
            "type": "number"
          },
          "dev_sell_pressure_5m": {
            "type": [
              "number",
              "null"
            ]
          },
          "launch_path_label": {
            "type": "string"
          },
          "pumpfun_to_raydium_sec": {
            "type": [
              "integer",
              "null"
            ]
          },
          "launch_path_confidence_score": {
            "type": "number"
          },
          "smart_wallet_hits": {
            "type": "integer"
          },
          "smart_wallet_hit_wallets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "wallet_registry_status": {
            "type": "string",
            "enum": [
              "validated",
              "degraded_missing_registry",
              "degraded_empty_registry"
            ]
          },
          "wallet_registry_hot_set_size": {
            "type": "integer"
          },
          "wallet_registry_validated_size": {
            "type": "integer"
          },
          "smart_wallet_score_sum": {
            "type": "number"
          },
          "smart_wallet_tier1_hits": {
            "type": "integer"
          },
          "smart_wallet_tier2_hits": {
            "type": "integer"
          },
          "smart_wallet_tier3_hits": {
            "type": "integer"
          },
          "smart_wallet_early_entry_hits": {
            "type": "integer"
          },
          "smart_wallet_active_hits": {
            "type": "integer"
          },
          "smart_wallet_watch_hits": {
            "type": "integer"
          },
          "smart_wallet_hit_tiers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "smart_wallet_hit_statuses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "smart_wallet_netflow_bias": {
            "type": [
              "number",
              "null"
            ]
          },
          "smart_wallet_conviction_bonus": {
            "type": "number"
          },
          "smart_wallet_registry_confidence": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "enrichment_status": {
            "type": "string",
            "enum": [
              "ok",
              "partial",
              "error"
            ]
          },
          "enrichment_warnings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "enriched_at": {
            "type": "string"
          },
          "contract_version": {
            "type": "string"
          }
        }
      }
    }
  }
}
