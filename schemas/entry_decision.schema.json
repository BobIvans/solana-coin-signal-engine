{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EntryDecision",
  "type": "object",
  "required": [
    "token_address",
    "entry_decision",
    "entry_confidence",
    "recommended_position_pct",
    "entry_reason",
    "entry_flags",
    "entry_warnings",
    "entry_snapshot",
    "entry_status",
    "decided_at",
    "contract_version"
  ],
  "properties": {
    "token_address": {"type": "string", "minLength": 1},
    "symbol": {"type": ["string", "null"]},
    "name": {"type": ["string", "null"]},
    "bundle_count_first_60s": {"type": ["integer", "null"]},
    "bundle_size_value": {"type": ["number", "null"]},
    "unique_wallets_per_bundle_avg": {"type": ["number", "null"]},
    "bundle_timing_from_liquidity_add_min": {"type": ["number", "null"]},
    "bundle_success_rate": {"type": ["number", "null"]},
    "bundle_composition_dominant": {"type": ["string", "null"]},
    "bundle_tip_efficiency": {"type": ["number", "null"]},
    "bundle_failure_retry_pattern": {"type": ["integer", "null"]},
    "cross_block_bundle_correlation": {"type": ["number", "null"]},
    "bundle_wallet_clustering_score": {"type": ["number", "null"]},
    "cluster_concentration_ratio": {"type": ["number", "null"]},
    "num_unique_clusters_first_60s": {"type": ["integer", "null"]},
    "creator_in_cluster_flag": {"type": ["boolean", "null"]},
    "entry_decision": {"type": "string", "enum": ["SCALP", "TREND", "IGNORE"]},
    "entry_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "recommended_position_pct": {"type": "number", "minimum": 0, "maximum": 1},
    "entry_reason": {"type": "string", "minLength": 1},
    "entry_flags": {"type": "array", "items": {"type": "string"}},
    "entry_warnings": {"type": "array", "items": {"type": "string"}},
    "entry_snapshot": {"type": "object"},
    "entry_status": {"type": "string"},
    "decided_at": {"type": "string"},
    "contract_version": {"type": "string"}
  },
  "additionalProperties": true
}
