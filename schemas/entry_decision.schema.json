{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EntryDecision",
  "type": "object",
  "required": [
    "token_address",
    "entry_decision",
    "entry_confidence",
    "recommended_position_pct",
    "entry_reason",
    "entry_flags",
    "entry_warnings",
    "entry_snapshot",
    "entry_status",
    "decided_at",
    "contract_version"
  ],
  "properties": {
    "token_address": {"type": "string", "minLength": 1},
    "symbol": {"type": ["string", "null"]},
    "name": {"type": ["string", "null"]},
    "entry_decision": {"type": "string", "enum": ["SCALP", "TREND", "IGNORE"]},
    "entry_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "recommended_position_pct": {"type": "number", "minimum": 0, "maximum": 1},
    "entry_reason": {"type": "string", "minLength": 1},
    "entry_flags": {"type": "array", "items": {"type": "string"}},
    "entry_warnings": {"type": "array", "items": {"type": "string"}},
    "entry_snapshot": {"type": "object"},
    "entry_status": {"type": "string"},
    "decided_at": {"type": "string"},
    "contract_version": {"type": "string"}
  },
  "additionalProperties": true
}
