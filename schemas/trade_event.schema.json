{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TradeEvent",
  "type": "object",
  "required": ["ts", "event", "trade_id", "token_address", "side", "contract_version"],
  "properties": {
    "ts": {"type": "string"},
    "event": {"type": "string", "enum": ["paper_buy", "paper_sell_partial", "paper_sell_full", "paper_fill_failed"]},
    "trade_id": {"type": "string"},
    "position_id": {"type": ["string", "null"]},
    "token_address": {"type": "string"},
    "bundle_count_first_60s": {"type": ["integer", "null"]},
    "bundle_size_value": {"type": ["number", "null"]},
    "unique_wallets_per_bundle_avg": {"type": ["number", "null"]},
    "bundle_timing_from_liquidity_add_min": {"type": ["number", "null"]},
    "bundle_success_rate": {"type": ["number", "null"]},
    "bundle_composition_dominant": {"type": ["string", "null"]},
    "bundle_tip_efficiency": {"type": ["number", "null"]},
    "bundle_failure_retry_pattern": {"type": ["string", "null"]},
    "cross_block_bundle_correlation": {"type": ["number", "null"]},
    "bundle_wallet_clustering_score": {"type": ["number", "null"]},
    "cluster_concentration_ratio": {"type": ["number", "null"]},
    "num_unique_clusters_first_60s": {"type": ["integer", "null"]},
    "creator_in_cluster_flag": {"type": ["boolean", "null"]},
    "symbol": {"type": ["string", "null"]},
    "side": {"type": "string", "enum": ["BUY", "SELL"]},
    "requested_notional_sol": {"type": ["number", "null"]},
    "filled_notional_sol": {"type": ["number", "null"]},
    "fill_ratio": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "reference_price_usd": {"type": ["number", "null"]},
    "executed_price_usd": {"type": ["number", "null"]},
    "slippage_bps": {"type": ["number", "null"]},
    "priority_fee_sol": {"type": ["number", "null"]},
    "tx_failed": {"type": ["boolean", "null"]},
    "failure_reason": {"type": ["string", "null"]},
    "contract_version": {"type": "string"}
  },
  "additionalProperties": true
}
