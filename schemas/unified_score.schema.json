{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unified scored token record",
  "type": "object",
  "required": [
    "token_address",
    "onchain_core",
    "early_signal_bonus",
    "bundle_aggression_bonus",
    "organic_multi_cluster_bonus",
    "single_cluster_penalty",
    "creator_cluster_penalty",
    "bundle_sell_heavy_penalty",
    "retry_manipulation_penalty",
    "x_validation_bonus",
    "rug_penalty",
    "spam_penalty",
    "confidence_adjustment",
    "final_score",
    "regime_candidate",
    "score_inputs_status",
    "score_flags",
    "score_warnings",
    "scored_at",
    "contract_version"
  ],
  "properties": {
    "token_address": {
      "type": "string",
      "minLength": 1
    },
    "symbol": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "fast_prescore": {
      "type": "number"
    },
    "bundle_count_first_60s": {
      "type": [
        "integer",
        "null"
      ]
    },
    "bundle_size_value": {
      "type": [
        "number",
        "null"
      ]
    },
    "unique_wallets_per_bundle_avg": {
      "type": [
        "number",
        "null"
      ]
    },
    "bundle_timing_from_liquidity_add_min": {
      "type": [
        "number",
        "null"
      ]
    },
    "bundle_success_rate": {
      "type": [
        "number",
        "null"
      ]
    },
    "bundle_composition_dominant": {
      "type": [
        "string",
        "null"
      ]
    },
    "bundle_tip_efficiency": {
      "type": [
        "number",
        "null"
      ]
    },
    "bundle_failure_retry_pattern": {
      "type": [
        "integer",
        "string",
        "null"
      ]
    },
    "cross_block_bundle_correlation": {
      "type": [
        "number",
        "null"
      ]
    },
    "bundle_wallet_clustering_score": {
      "type": [
        "number",
        "null"
      ]
    },
    "cluster_concentration_ratio": {
      "type": [
        "number",
        "null"
      ]
    },
    "num_unique_clusters_first_60s": {
      "type": [
        "integer",
        "null"
      ]
    },
    "creator_in_cluster_flag": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "onchain_core": {
      "type": "number",
      "minimum": 0,
      "maximum": 45
    },
    "early_signal_bonus": {
      "type": "number",
      "minimum": 0,
      "maximum": 25
    },
    "bundle_aggression_bonus": {
      "type": "number",
      "minimum": 0,
      "maximum": 6
    },
    "organic_multi_cluster_bonus": {
      "type": "number",
      "minimum": 0,
      "maximum": 4
    },
    "single_cluster_penalty": {
      "type": "number",
      "minimum": 0,
      "maximum": 6
    },
    "creator_cluster_penalty": {
      "type": "number",
      "minimum": 0,
      "maximum": 4
    },
    "bundle_sell_heavy_penalty": {
      "type": "number",
      "minimum": 0,
      "maximum": 5
    },
    "retry_manipulation_penalty": {
      "type": "number",
      "minimum": 0,
      "maximum": 4
    },
    "x_validation_bonus": {
      "type": "number",
      "minimum": 0,
      "maximum": 14
    },
    "rug_penalty": {
      "type": "number",
      "minimum": 0,
      "maximum": 40
    },
    "spam_penalty": {
      "type": "number",
      "minimum": 0,
      "maximum": 8
    },
    "confidence_adjustment": {
      "type": "number",
      "minimum": -25,
      "maximum": 5
    },
    "wallet_adjustment": {
      "type": [
        "object",
        "null"
      ]
    },
    "final_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "regime_candidate": {
      "type": "string",
      "enum": [
        "IGNORE",
        "WATCHLIST",
        "ENTRY_CANDIDATE"
      ]
    },
    "score_inputs_status": {
      "type": "object"
    },
    "score_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "score_warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scored_at": {
      "type": "string"
    },
    "contract_version": {
      "type": "string",
      "const": "unified_score_v1"
    },
    "net_unique_buyers_60s": {
      "type": [
        "integer",
        "null"
      ]
    },
    "liquidity_refill_ratio_120s": {
      "type": [
        "number",
        "null"
      ]
    },
    "cluster_sell_concentration_120s": {
      "type": [
        "number",
        "null"
      ]
    },
    "smart_wallet_dispersion_score": {
      "type": [
        "number",
        "null"
      ]
    },
    "x_author_velocity_5m": {
      "type": [
        "number",
        "null"
      ]
    },
    "seller_reentry_ratio": {
      "type": [
        "number",
        "null"
      ]
    },
    "liquidity_shock_recovery_sec": {
      "type": [
        "integer",
        "null"
      ]
    }
  },
  "additionalProperties": true
}
