{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unified scored token record",
  "type": "object",
  "required": [
    "token_address",
    "onchain_core",
    "early_signal_bonus",
    "x_validation_bonus",
    "rug_penalty",
    "spam_penalty",
    "confidence_adjustment",
    "final_score",
    "regime_candidate",
    "score_inputs_status",
    "score_flags",
    "score_warnings",
    "scored_at",
    "contract_version"
  ],
  "properties": {
    "token_address": {"type": "string", "minLength": 1},
    "bundle_count_first_60s": {"type": ["integer", "null"]},
    "bundle_size_value": {"type": ["number", "null"]},
    "unique_wallets_per_bundle_avg": {"type": ["number", "null"]},
    "bundle_timing_from_liquidity_add_min": {"type": ["number", "null"]},
    "bundle_success_rate": {"type": ["number", "null"]},
    "bundle_composition_dominant": {"type": ["string", "null"]},
    "bundle_tip_efficiency": {"type": ["number", "null"]},
    "bundle_failure_retry_pattern": {"type": ["integer", "null"]},
    "cross_block_bundle_correlation": {"type": ["number", "null"]},
    "bundle_wallet_clustering_score": {"type": ["number", "null"]},
    "cluster_concentration_ratio": {"type": ["number", "null"]},
    "num_unique_clusters_first_60s": {"type": ["integer", "null"]},
    "creator_in_cluster_flag": {"type": ["boolean", "null"]},
    "onchain_core": {"type": "number", "minimum": 0, "maximum": 45},
    "early_signal_bonus": {"type": "number", "minimum": 0, "maximum": 25},
    "x_validation_bonus": {"type": "number", "minimum": 0, "maximum": 14},
    "rug_penalty": {"type": "number", "minimum": 0, "maximum": 40},
    "spam_penalty": {"type": "number", "minimum": 0, "maximum": 8},
    "confidence_adjustment": {"type": "number", "minimum": -25, "maximum": 5},
    "final_score": {"type": "number", "minimum": 0, "maximum": 100},
    "regime_candidate": {"type": "string", "enum": ["IGNORE", "WATCHLIST", "ENTRY_CANDIDATE"]},
    "score_inputs_status": {"type": "object"},
    "score_flags": {"type": "array", "items": {"type": "string"}},
    "score_warnings": {"type": "array", "items": {"type": "string"}},
    "scored_at": {"type": "string"},
    "contract_version": {"type": "string", "const": "unified_score_v1"}
  },
  "additionalProperties": true
}
