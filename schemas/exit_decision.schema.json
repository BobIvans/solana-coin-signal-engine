{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExitDecision",
  "type": "object",
  "required": [
    "position_id",
    "token_address",
    "exit_decision",
    "exit_fraction",
    "exit_reason",
    "hold_sec",
    "pnl_pct",
    "exit_snapshot",
    "exit_status",
    "decided_at",
    "contract_version"
  ],
  "properties": {
    "position_id": {"type": "string"},
    "token_address": {"type": "string"},
    "symbol": {"type": ["string", "null"]},
    "exit_decision": {"type": "string", "enum": ["HOLD", "PARTIAL_EXIT", "FULL_EXIT"]},
    "exit_fraction": {"type": "number", "minimum": 0, "maximum": 1},
    "exit_reason": {"type": "string"},
    "hold_sec": {"type": "integer", "minimum": 0},
    "pnl_pct": {"type": "number"},
    "exit_flags": {"type": "array", "items": {"type": "string"}},
    "exit_warnings": {"type": "array", "items": {"type": "string"}},
    "exit_snapshot": {
      "type": "object",
      "required": [
        "price_usd",
        "buy_pressure_now",
        "volume_velocity_now",
        "liquidity_usd_now",
        "liquidity_drop_pct",
        "x_validation_score_now",
        "x_status_now",
        "bundle_cluster_score_now",
        "bundle_cluster_delta",
        "dev_sell_pressure_now",
        "rug_flag_now"
      ],
      "properties": {
        "bundle_count_first_60s": {"type": ["integer", "null"]},
        "bundle_size_value": {"type": ["number", "null"]},
        "unique_wallets_per_bundle_avg": {"type": ["number", "null"]},
        "bundle_timing_from_liquidity_add_min": {"type": ["number", "null"]},
        "bundle_success_rate": {"type": ["number", "null"]},
        "bundle_composition_dominant": {"type": ["string", "null"]},
        "bundle_tip_efficiency": {"type": ["number", "null"]},
        "bundle_failure_retry_pattern": {"type": ["integer", "null"]},
        "cross_block_bundle_correlation": {"type": ["number", "null"]},
        "bundle_wallet_clustering_score": {"type": ["number", "null"]},
        "cluster_concentration_ratio": {"type": ["number", "null"]},
        "num_unique_clusters_first_60s": {"type": ["integer", "null"]},
        "creator_in_cluster_flag": {"type": ["boolean", "null"]}
      }
    },
    "exit_status": {"type": "string", "enum": ["ok", "partial"]},
    "decided_at": {"type": "string"},
    "contract_version": {"type": "string"}
  }
}
