{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "smart_wallet_registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "generated_at",
    "input_summary",
    "registry_summary",
    "wallets"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "smart_wallet_registry.v1"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "input_summary": {
      "type": "object",
      "additionalProperties": true
    },
    "registry_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_candidates",
        "kept_wallets",
        "rejected_wallets",
        "tier_1_count",
        "tier_2_count",
        "tier_3_count",
        "active_count",
        "watch_count"
      ],
      "properties": {
        "total_candidates": { "type": "integer", "minimum": 0 },
        "kept_wallets": { "type": "integer", "minimum": 0 },
        "rejected_wallets": { "type": "integer", "minimum": 0 },
        "tier_1_count": { "type": "integer", "minimum": 0 },
        "tier_2_count": { "type": "integer", "minimum": 0 },
        "tier_3_count": { "type": "integer", "minimum": 0 },
        "active_count": { "type": "integer", "minimum": 0 },
        "watch_count": { "type": "integer", "minimum": 0 }
      }
    },
    "wallets": {
      "type": "array",
      "items": { "$ref": "#/$defs/walletRecord" }
    }
  },
  "$defs": {
    "walletRecord": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "wallet",
        "status",
        "tier",
        "registry_score",
        "source_names",
        "source_count",
        "manual_priority",
        "tags",
        "notes",
        "quality_flags",
        "filter_reasons",
        "regime_fit_scalp",
        "regime_fit_trend",
        "watch_priority",
        "hot_priority",
        "added_at",
        "updated_at"
      ],
      "properties": {
        "wallet": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["active", "watch", "rejected"] },
        "tier": { "type": "string", "enum": ["tier_1", "tier_2", "tier_3", "rejected"] },
        "registry_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "source_names": { "type": "array", "items": { "type": "string" } },
        "source_count": { "type": "integer", "minimum": 0 },
        "manual_priority": { "type": "boolean" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" },
        "quality_flags": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "invalid_format_rejected",
            "duplicate_source_merged",
            "manual_seed",
            "sparse_metadata",
            "requires_replay_validation"
          ],
          "properties": {
            "invalid_format_rejected": { "type": "boolean" },
            "duplicate_source_merged": { "type": "boolean" },
            "manual_seed": { "type": "boolean" },
            "sparse_metadata": { "type": "boolean" },
            "requires_replay_validation": { "type": "boolean" }
          }
        },
        "filter_reasons": { "type": "array", "items": { "type": "string" } },
        "regime_fit_scalp": { "type": "number", "minimum": 0, "maximum": 1 },
        "regime_fit_trend": { "type": "number", "minimum": 0, "maximum": 1 },
        "watch_priority": { "type": "number" },
        "hot_priority": { "type": "number" },
        "added_at": { "type": "string", "minLength": 1 },
        "updated_at": { "type": "string", "minLength": 1 }
      }
    }
  }
}
